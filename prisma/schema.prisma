generator client { provider = "prisma-client-js" }
datasource db { provider = "sqlite" url = env("DATABASE_URL") }
model AuditLog { id String @id @default(cuid()) actor String action String metadata Json? createdAt DateTime @default(now()) }
model CachedChart { id String @id @default(cuid()) trainNumber String journeyDate DateTime source String destination String payload Json createdAt DateTime @default(now()) @@index([trainNumber, journeyDate]) }
